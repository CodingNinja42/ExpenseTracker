@model IEnumerable<ExpenseTracker.Models.Transaction>
@{
    ViewData["Title"] = "Transactions";
}

<div class="page-header-row">
    <div class="page-header-info">
        <p class="page-subtitle">View and manage all your transactions</p>
    </div>
    <a asp-action="AddOrEdit" class="btn-premium" id="btn-add-transaction">
        <i class="fas fa-plus"></i> Add Transaction
    </a>
</div>

<div class="card-glass">
    <div class="table-responsive">
        <table class="table premium-table" id="transactions-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Note</th>
                    <th style="width: 160px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="category-badge">
                                @item.CategoryTitleWithIcon
                            </span>
                        </td>
                        <td>@item.Date.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="@(item.Category?.Type == "Income" ? "amount-income" : "amount-expense")">
                                @item.FormattedAmount
                            </span>
                        </td>
                        <td><span class="note-text">@(item.Note ?? "—")</span></td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="AddOrEdit" asp-route-id="@item.TransactionId" class="btn-action btn-edit" title="Edit">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.TransactionId" method="post" style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to delete this transaction?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action btn-delete" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-exchange-alt"></i>
            <h4>No transactions yet</h4>
            <p>Add your first transaction to start tracking</p>
            <a asp-action="AddOrEdit" class="btn-premium">
                <i class="fas fa-plus"></i> Add Transaction
            </a>
        </div>
    }
</div>
